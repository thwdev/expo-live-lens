{
  "name": "expo-live-lens",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source AI devtools for Expo Go and React Native: screenshots, logs, network events, replay sessions, and prompts for Codex and Claude.",
  "homepage": "https://github.com/thwdev/expo-live-lens#readme",
  "bugs": {
    "url": "https://github.com/thwdev/expo-live-lens/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thwdev/expo-live-lens.git"
  },
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "dev": "node src/server.mjs",
    "dev:dashboard": "node src/server.mjs",
    "dev:demo": "npm.cmd --prefix examples/demo-expo start",
    "dev:demo:offline": "npm.cmd --prefix examples/demo-expo run start:offline",
    "review:summary": "node scripts/pull-summary.mjs",
    "review:pull": "node scripts/pull-review-packet.mjs",
    "review:prompt": "node scripts/pull-review-prompt.mjs",
    "review:mobile": "node scripts/pull-review-prompt.mjs mobile",
    "mobile:insights": "node scripts/pull-mobile-insights.mjs",
    "timeline:pull": "node scripts/pull-timeline.mjs",
    "capture:now": "node scripts/request-capture.mjs codex",
    "session:start": "node scripts/session.mjs start",
    "session:stop": "node scripts/session.mjs stop",
    "session:pull": "node scripts/session.mjs pull",
    "review:now": "node scripts/pull-review-packet.mjs --now",
    "setup:app": "node scripts/setup-expo-app.mjs",
    "start": "node src/server.mjs",
    "check": "node --check src/server.mjs"
  },
  "keywords": [
    "expo",
    "expo-go",
    "expo-router",
    "react-native",
    "devtools",
    "mobile-devtools",
    "debugging",
    "inspector",
    "ai",
    "codex",
    "claude",
    "ai-coding",
    "screenshots",
    "radon-alternative"
  ],
  "license": "MIT"
}
